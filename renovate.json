{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "pinDigests": true,
  "packageRules": [
    {
      "description": "Auto-merge Go version and module updates",
      "matchManagers": ["gomod"],
      "automerge": true
    },
    {
      "description": "Auto-merge Docker base image updates",
      "matchManagers": ["dockerfile"],
      "automerge": true
    },
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "automerge": true
    }
  ]
}
